# ── LLM ────────────────────────────────────────────────────────────────────
# Leave blank to run in MOCK mode (no API key required for demo)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Database ────────────────────────────────────────────────────────────────
DB_PATH=data/pipeline.db

# ── Pipeline ────────────────────────────────────────────────────────────────
BATCH_SIZE=10
PILOT_MAX_URLS=50
MIN_POSTS_PER_WEEK=2
MAX_POSTS_PER_WEEK=4

# ── Hub WordPress endpoints (leave blank for mock publishing) ────────────────
HUB1_WP_URL=
HUB1_WP_USER=
HUB1_WP_PASSWORD=

HUB2_WP_URL=
HUB2_WP_USER=
HUB2_WP_PASSWORD=

HUB3_WP_URL=
HUB3_WP_USER=
HUB3_WP_PASSWORD=

HUB4_WP_URL=
HUB4_WP_USER=
HUB4_WP_PASSWORD=

HUB5_WP_URL=
HUB5_WP_USER=
HUB5_WP_PASSWORD=
